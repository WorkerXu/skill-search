{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillQuick",
  "version": "0.1.0",
  "identifier": "com.coderxu.skillquick",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "DeveloperTool",
    "shortDescription": "Quick local skill lookup",
    "longDescription": "Search local skill markdown files and copy their absolute paths."
  }
}
